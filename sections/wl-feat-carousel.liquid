{{ 'wl-feat-carousel.css' | asset_url | stylesheet_tag }}

<div class="wl-feat-carousel color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="wl-feat-carousel__heading">
      {%- if section.settings.eyebrow != blank -%}
        <p class="wl-feat-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="wl-feat-carousel__title {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>
  </div>

  <div class="wl-feat-carousel__outer">
    <div
      class="wl-feat-carousel__track"
      id="WlFeatCarouselTrack-{{ section.id }}"
      aria-live="polite"
    >
      {%- for block in section.blocks -%}
        <div
          class="wl-feat-carousel__slide"
          style="background-color: {{ block.settings.background_color }};"
          aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
          role="group"
          {{ block.shopify_attributes }}
        >
          <div class="wl-feat-carousel__slide-inner page-width">

            <div class="wl-feat-carousel__slide-text">
              {%- if block.settings.eyebrow != blank -%}
                <p class="wl-feat-carousel__eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="wl-feat-carousel__slide-heading">
                  {{ block.settings.heading }}
                </h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="wl-feat-carousel__slide-body rte">
                  {{ block.settings.body }}
                </div>
              {%- endif -%}
              <div class="wl-feat-carousel__slide-btns">
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link }}"
                    class="button button--primary"
                  >
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a
                    href="{{ block.settings.button_link_2 }}"
                    class="button button--secondary"
                  >
                    {{ block.settings.button_label_2 }}
                  </a>
                {%- endif -%}
              </div>
            </div>

            <div class="wl-feat-carousel__slide-image">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt, class: 'wl-feat-carousel__img' }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'wl-feat-carousel__img placeholder-svg' }}
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button
        type="button"
        class="wl-feat-carousel__arrow wl-feat-carousel__arrow--prev"
        onclick="WlFeatCarousel.move('{{ section.id }}', -1)"
        aria-label="Previous slide"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <button
        type="button"
        class="wl-feat-carousel__arrow wl-feat-carousel__arrow--next"
        onclick="WlFeatCarousel.move('{{ section.id }}', 1)"
        aria-label="Next slide"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>

      <div class="wl-feat-carousel__dots" role="tablist">
        {%- for block in section.blocks -%}
          <button
            class="wl-feat-carousel__dot{% if forloop.first %} active{% endif %}"
            onclick="WlFeatCarousel.goTo('{{ section.id }}', {{ forloop.index0 }})"
            aria-label="Go to slide {{ forloop.index }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
var WlFeatCarousel = (function () {
  var state = {};
  var timers = {};

  function getTrack(id) {
    return document.getElementById('WlFeatCarouselTrack-' + id);
  }

  function render(id) {
    var track = getTrack(id);
    if (!track) return;
    var idx = state[id] || 0;
    track.style.transform = 'translateX(' + (-idx * 100) + '%)';
    track
      .closest('.wl-feat-carousel__outer')
      .querySelectorAll('.wl-feat-carousel__dot')
      .forEach(function (dot, i) {
        dot.classList.toggle('active', i === idx);
        dot.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
  }

  function startAutoplay(id, interval) {
    stopAutoplay(id);
    timers[id] = setInterval(function () {
      var track = getTrack(id);
      if (!track) return;
      var count = track.children.length;
      state[id] = ((state[id] || 0) + 1) % count;
      render(id);
    }, interval);
  }

  function stopAutoplay(id) {
    if (timers[id]) {
      clearInterval(timers[id]);
      timers[id] = null;
    }
  }

  return {
    init: function (id, interval) {
      if (!interval || interval <= 0) return;
      // Always clear any existing timer first — prevents duplicate intervals
      // when Shopify editor hot-reloads the section
      stopAutoplay(id);
      var container = getTrack(id) && getTrack(id).closest('.wl-feat-carousel__outer');
      startAutoplay(id, interval);
      if (container) {
        container.addEventListener('mouseenter', function () { stopAutoplay(id); });
        container.addEventListener('mouseleave', function () { startAutoplay(id, interval); });
        container.addEventListener('focusin',    function () { stopAutoplay(id); });
        container.addEventListener('focusout',   function () { startAutoplay(id, interval); });
      }
    },
    destroy: function (id) {
      stopAutoplay(id);
      delete state[id];
    },
    move: function (id, dir) {
      var track = getTrack(id);
      if (!track) return;
      var count = track.children.length;
      state[id] = ((state[id] || 0) + dir + count) % count;
      render(id);
    },
    goTo: function (id, idx) {
      state[id] = idx;
      render(id);
    }
  };
})();

{%- if section.settings.autoplay and section.blocks.size > 1 -%}
  WlFeatCarousel.init('{{ section.id }}', {{ section.settings.autoplay_speed | times: 1000 }});
{%- endif -%}

document.addEventListener('shopify:section:unload', function (e) {
  if (e.detail.sectionId === '{{ section.id }}') {
    WlFeatCarousel.destroy('{{ section.id }}');
  }
});

document.addEventListener('shopify:section:reorder', function (e) {
  if (e.detail.sectionId === '{{ section.id }}') {
    WlFeatCarousel.destroy('{{ section.id }}');
  }
});
</script>

{% schema %}
{
  "name": "WL Featured Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Featured collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Something for everyone"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 6,
      "settings": [
        {
          "type": "color",
          "id": "background_color",
          "label": "Slide background color",
          "default": "#DAEEFA"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Primary button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Secondary button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product / collection image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WL — Featured Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
