{{ 'wl-tokens.css' | asset_url | stylesheet_tag }}
{{ 'wl-feat-carousel.css' | asset_url | stylesheet_tag }}

<div class="wl-feat-carousel color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="wl-feat-carousel__heading">
      {%- if section.settings.eyebrow != blank -%}
        <p class="wl-feat-carousel__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="wl-feat-carousel__title {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>
  </div>

  <div class="wl-feat-carousel__outer">
    <div
      class="wl-feat-carousel__track"
      id="WlFeatCarouselTrack-{{ section.id }}"
      aria-live="polite"
    >
      {%- for block in section.blocks -%}
        <div
          class="wl-feat-carousel__slide"
          style="background-color: {{ block.settings.background_color }};"
          aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
          role="group"
          {{ block.shopify_attributes }}
        >
          <div class="wl-feat-carousel__slide-inner page-width">

            {%- if block.type == 'product_slide' -%}
              {%- assign slide_product = block.settings.product -%}
              <div class="wl-feat-carousel__slide-text wl-feat-carousel__slide-text--product">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="wl-feat-carousel__eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}
                <h3 class="wl-feat-carousel__slide-heading">
                  {{ block.settings.heading | default: slide_product.title }}
                </h3>
                {%- if slide_product != blank -%}
                  <p class="wl-feat-carousel__slide-price">
                    {%- if slide_product.price_varies -%}
                      From {{ slide_product.price_min | money }}
                    {%- else -%}
                      {{ slide_product.price | money }}
                    {%- endif -%}
                  </p>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="wl-feat-carousel__slide-body rte">{{ block.settings.body }}</div>
                {%- endif -%}
                <div class="wl-feat-carousel__slide-btns">
                  {%- if slide_product != blank -%}
                    {%- if slide_product.available == false -%}
                      <button class="button button--primary" disabled>Sold out</button>
                    {%- elsif slide_product.variants.size == 1 and slide_product.template_suffix != 'personalizable' and slide_product.template_suffix != 'personalizable-text' -%}
                      <form action="/cart/add" method="post">
                        <input type="hidden" name="id" value="{{ slide_product.selected_or_first_available_variant.id }}">
                        <button type="submit" class="button button--primary">Add to cart</button>
                      </form>
                    {%- else -%}
                      <a href="{{ slide_product.url }}" class="button button--primary">Choose options</a>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
              <div class="wl-feat-carousel__slide-image wl-feat-carousel__slide-image--product">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt, class: 'wl-feat-carousel__img' }}
                {%- elsif slide_product != blank and slide_product.featured_image != blank -%}
                  {%- assign prod_img_alt = slide_product.featured_image.alt | default: slide_product.title -%}
                  {{ slide_product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: prod_img_alt, class: 'wl-feat-carousel__img' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'wl-feat-carousel__img placeholder-svg' }}
                {%- endif -%}
              </div>

            {%- elsif block.type == 'link_slide' -%}
              <div class="wl-feat-carousel__slide-text">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="wl-feat-carousel__eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="wl-feat-carousel__slide-heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="wl-feat-carousel__slide-body rte">{{ block.settings.body }}</div>
                {%- endif -%}
                <div class="wl-feat-carousel__slide-btns">
                  {%- if block.settings.button_label != blank -%}
                    <a href="{{ block.settings.button_link }}" class="button button--primary">
                      {{ block.settings.button_label }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank -%}
                    <a href="{{ block.settings.button_link_2 }}" class="button button--secondary">
                      {{ block.settings.button_label_2 }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
              <div class="wl-feat-carousel__slide-image">
                {%- if block.settings.image_asset != blank -%}
                  <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.heading | escape }}" class="wl-feat-carousel__img" loading="lazy">
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.image.alt, class: 'wl-feat-carousel__img' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'wl-feat-carousel__img placeholder-svg' }}
                {%- endif -%}
              </div>
            {%- endif -%}

          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button
        type="button"
        class="wl-feat-carousel__arrow wl-feat-carousel__arrow--prev"
        onclick="WlFeatCarousel.move('{{ section.id }}', -1)"
        aria-label="Previous slide"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
      <button
        type="button"
        class="wl-feat-carousel__arrow wl-feat-carousel__arrow--next"
        onclick="WlFeatCarousel.move('{{ section.id }}', 1)"
        aria-label="Next slide"
      >
        <span class="svg-wrapper">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>

      <div class="wl-feat-carousel__dots" role="tablist">
        {%- for block in section.blocks -%}
          <button
            class="wl-feat-carousel__dot{% if forloop.first %} active{% endif %}"
            onclick="WlFeatCarousel.goTo('{{ section.id }}', {{ forloop.index0 }})"
            aria-label="Go to slide {{ forloop.index }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
var WlFeatCarousel = (function () {
  var state = {};
  var timers = {};

  function getTrack(id) {
    return document.getElementById('WlFeatCarouselTrack-' + id);
  }

  function render(id) {
    var track = getTrack(id);
    if (!track) return;
    var idx = state[id] || 0;
    track.style.transform = 'translateX(' + (-idx * 100) + '%)';
    track
      .closest('.wl-feat-carousel__outer')
      .querySelectorAll('.wl-feat-carousel__dot')
      .forEach(function (dot, i) {
        dot.classList.toggle('active', i === idx);
        dot.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
  }

  function startAutoplay(id, interval) {
    stopAutoplay(id);
    timers[id] = setInterval(function () {
      var track = getTrack(id);
      if (!track) return;
      var count = track.children.length;
      state[id] = ((state[id] || 0) + 1) % count;
      render(id);
    }, interval);
  }

  function stopAutoplay(id) {
    if (timers[id]) {
      clearInterval(timers[id]);
      timers[id] = null;
    }
  }

  return {
    init: function (id, interval) {
      if (!interval || interval <= 0) return;
      // Always clear any existing timer first — prevents duplicate intervals
      // when Shopify editor hot-reloads the section
      stopAutoplay(id);
      var container = getTrack(id) && getTrack(id).closest('.wl-feat-carousel__outer');
      startAutoplay(id, interval);
      if (container) {
        container.addEventListener('mouseenter', function () { stopAutoplay(id); });
        container.addEventListener('mouseleave', function () { startAutoplay(id, interval); });
        container.addEventListener('focusin',    function () { stopAutoplay(id); });
        container.addEventListener('focusout',   function () { startAutoplay(id, interval); });
      }
    },
    destroy: function (id) {
      stopAutoplay(id);
      delete state[id];
    },
    move: function (id, dir) {
      var track = getTrack(id);
      if (!track) return;
      var count = track.children.length;
      state[id] = ((state[id] || 0) + dir + count) % count;
      render(id);
    },
    goTo: function (id, idx) {
      state[id] = idx;
      render(id);
    }
  };
})();

{%- if section.settings.autoplay and section.blocks.size > 1 -%}
  WlFeatCarousel.init('{{ section.id }}', {{ section.settings.autoplay_speed | times: 1000 }});
{%- endif -%}

document.addEventListener('shopify:section:unload', function (e) {
  if (e.detail.sectionId === '{{ section.id }}') {
    WlFeatCarousel.destroy('{{ section.id }}');
  }
});

document.addEventListener('shopify:section:reorder', function (e) {
  if (e.detail.sectionId === '{{ section.id }}') {
    WlFeatCarousel.destroy('{{ section.id }}');
  }
});
</script>

{% schema %}
{
  "name": "WL Featured Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Featured collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Something for everyone"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "product_slide",
      "name": "Product Feature",
      "limit": 6,
      "settings": [
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#DAEEFA"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "Optional. Replaces the product image. Use for lifestyle shots or custom crops."
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "Leave blank to use the product title."
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        }
      ]
    },
    {
      "type": "link_slide",
      "name": "Collection / Link",
      "limit": 6,
      "settings": [
        {
          "type": "color",
          "id": "background_color",
          "label": "Background color",
          "default": "#DAEEFA"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image asset filename",
          "info": "Filename of an image in the theme assets folder (e.g. pen-business-and-events.jpg). Takes priority over the image picker below."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Primary button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Primary button link"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Secondary button label"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WL Featured Carousel",
      "blocks": [
        { "type": "product_slide" },
        { "type": "link_slide" },
        { "type": "link_slide" }
      ]
    }
  ]
}
{% endschema %}
