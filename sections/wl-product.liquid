{{ 'wl-tokens.css' | asset_url | stylesheet_tag }}
{{ 'wl-buttons.css' | asset_url | stylesheet_tag }}
{{ 'wl-product.css' | asset_url | stylesheet_tag }}
{{ 'filepond.min.css' | asset_url | stylesheet_tag }}
{{ 'filepond-plugin-image-preview.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'filepond.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'filepond-plugin-image-preview.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'filepond-plugin-file-validate-type.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'filepond-plugin-file-validate-size.min.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'wl-pf-' | append: section.id | append: '-' | append: product.id
  assign show_pers = section.settings.show_personalization
-%}

<div class="page-width">
  <div class="wl-pd">

    {%- comment -%} ── MEDIA ── {%- endcomment -%}
    <div class="wl-pd__media">
      <div class="wl-pd__main-img">
        {%- if product.featured_media -%}
          <img
            id="WlPdImg-{{ section.id }}"
            src="{{ product.featured_media | image_url: width: 800 }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            width="{{ product.featured_media.width }}"
            height="{{ product.featured_media.height }}"
            loading="eager"
          >
        {%- else -%}
          <div class="wl-pd__img-placeholder">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--wl-gray-300)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="wl-pd__thumbs">
          {%- for media in product.media -%}
            <button
              type="button"
              class="wl-pd__thumb{% if forloop.first %} is-active{% endif %}"
              data-src="{{ media | image_url: width: 800 }}"
              data-alt="{{ media.alt | default: product.title | escape }}"
              onclick="WlPd.setMedia(this, '{{ section.id }}')"
              aria-label="View image {{ forloop.index }}"
            >
              <img src="{{ media | image_url: width: 120 }}" alt="" width="72" height="72" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── INFO ── {%- endcomment -%}
    <div class="wl-pd__info">

      {%- comment -%} Eyebrow + badge {%- endcomment -%}
      <p class="wl-pd__eyebrow">
        {%- if product.collections.first -%}
          <a href="{{ product.collections.first.url }}" class="wl-pd__eyebrow-link">{{ product.collections.first.title }}</a>
        {%- endif -%}
        {%- if current_variant.available == false -%}
          <span class="wl-badge wl-badge--sold-out">Sold out</span>
        {%- elsif product.compare_at_price > product.price -%}
          <span class="wl-badge wl-badge--sale">Sale</span>
        {%- elsif product.tags contains 'best-seller' or product.tags contains 'Best Seller' or product.tags contains 'bestseller' -%}
          <span class="wl-badge wl-badge--hot">Best seller</span>
        {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
          <span class="wl-badge wl-badge--new">New</span>
        {%- endif -%}
      </p>

      <h1 class="wl-pd__title">{{ product.title | escape }}</h1>

      {%- comment -%} Price {%- endcomment -%}
      <div class="wl-pd__price-row" id="WlPdPriceRow-{{ section.id }}">
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <s class="wl-pd__price-was" id="WlPdPriceWas-{{ section.id }}">{{ current_variant.compare_at_price | money }}</s>
        {%- else -%}
          <s class="wl-pd__price-was" id="WlPdPriceWas-{{ section.id }}" hidden></s>
        {%- endif -%}
        <span class="wl-pd__price" id="WlPdPrice-{{ section.id }}">{{ current_variant.price | money }}</span>
        {%- if section.settings.price_note != blank -%}
          <span class="wl-pd__price-note">{{ section.settings.price_note }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Feature badges {%- endcomment -%}
      {%- assign badge_blocks = section.blocks | where: 'type', 'badge' -%}
      {%- if badge_blocks.size > 0 -%}
        <div class="wl-pd__feat-badges">
          {%- for block in badge_blocks -%}
            <span class="wl-pd__feat-badge wl-pd__feat-badge--{{ block.settings.style }}" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Variant options {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        <div class="wl-pd__options" id="WlPdOptions-{{ section.id }}">
          {%- for option in product.options_with_values -%}
            <div class="wl-pd__option-group">
              <div class="wl-pd__option-label">
                {{ option.name }}:
                <span id="WlPdOptVal-{{ section.id }}-{{ forloop.index0 }}">{{ option.selected_value }}</span>
              </div>
              <div class="wl-pd__pills" role="group" aria-label="{{ option.name | escape }}">
                {%- for value in option.values -%}
                  <button
                    type="button"
                    class="wl-pd__pill{% if value == option.selected_value %} is-active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                    onclick="WlPd.selectOption(this, '{{ section.id }}')"
                    aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
                  >{{ value | escape }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      {%- comment -%} Personalization panel {%- endcomment -%}
      {%- if show_pers -%}
        <div class="wl-pd__pers">
          <div class="wl-pd__pers-title">
            <span class="wl-pd__pers-icon" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </span>
            {{ section.settings.personalization_heading | default: 'Personalize your item' }}
          </div>

          {%- if section.settings.show_text_field -%}
            <div class="wl-pd__pers-field">
              <label class="wl-pd__pers-label" for="WlPersText-{{ section.id }}">
                {{ section.settings.text_field_label | default: 'Custom text (optional)' }}
              </label>
              <input
                class="wl-pd__pers-input"
                type="text"
                id="WlPersText-{{ section.id }}"
                name="properties[{{ section.settings.text_field_property | default: 'Custom text' }}]"
                placeholder="{{ section.settings.text_field_placeholder | default: "e.g. Mom's Favorite, Best Dad..." }}"
                form="{{ product_form_id }}"
                maxlength="{{ section.settings.text_field_max_length | default: 80 }}"
              >
            </div>
          {%- endif -%}

          {%- if section.settings.show_upload_field -%}
            <div class="wl-pd__pers-field">
              <div class="wl-pd__pers-label">{{ section.settings.upload_field_label | default: 'Upload your photo' }}</div>
              <input
                type="file"
                id="WlPersUpload-{{ section.id }}"
                class="wl-pd__filepond"
                accept="image/jpeg,image/png,image/heic,image/heif"
                data-endpoint="{{ section.settings.upload_endpoint | escape }}"
              >
              <input
                type="hidden"
                id="WlPersPhotoUrl-{{ section.id }}"
                name="properties[Photo URL]"
                form="{{ product_form_id }}"
                value=""
              >
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if show_pers -%}
        {%- for block in section.blocks -%}
          {%- if block.type == '@app' -%}
            {% render block %}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- comment -%} Form: qty + add to cart {%- endcomment -%}
      <product-form data-section-id="{{ section.id }}" data-hide-errors="false">
        {%- form 'product', product,
          id: product_form_id,
          class: 'wl-pd__form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id }}"
            id="WlPdVariantId-{{ section.id }}"
            class="product-variant-id"
          >

          <div class="wl-pd__qty-row">
            <span class="wl-pd__qty-label">{{ 'products.product.quantity.label' | t }}</span>
            <div class="wl-pd__qty-ctrl">
              <button type="button" class="wl-pd__qty-btn" onclick="WlPd.adjustQty(-1,'{{ section.id }}')" aria-label="Decrease quantity">−</button>
              <input
                type="number"
                id="WlPdQty-{{ section.id }}"
                class="wl-pd__qty-input quantity__input"
                name="quantity"
                value="1"
                min="1"
                aria-label="{{ 'products.product.quantity.label' | t }}"
              >
              <button type="button" class="wl-pd__qty-btn" onclick="WlPd.adjustQty(1,'{{ section.id }}')" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <div class="wl-pd__cta-stack">
            <button
              type="submit"
              name="add"
              class="wl-pd__btn-add"
              id="WlPdAddBtn-{{ section.id }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span id="WlPdAddLabel-{{ section.id }}">
                {%- if current_variant.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </span>
              {%- render 'loading-spinner' -%}
            </button>
            {%- if section.settings.show_dynamic_checkout -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>

        {%- endform -%}
      </product-form>

      {%- comment -%} Trust strip {%- endcomment -%}
      {%- assign trust_blocks = section.blocks | where: 'type', 'trust_item' -%}
      {%- if trust_blocks.size > 0 -%}
        <div class="wl-pd__trust">
          {%- for block in trust_blocks -%}
            <div class="wl-pd__trust-item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <span class="wl-pd__trust-icon" aria-hidden="true">{{ block.settings.icon }}</span>
              {%- endif -%}
              <div class="wl-pd__trust-text">
                {%- if block.settings.title != blank -%}<strong>{{ block.settings.title }}</strong>{%- endif -%}
                {%- if block.settings.body != blank -%}{{ block.settings.body }}{%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Accordion {%- endcomment -%}
      {%- assign acc_blocks = section.blocks | where: 'type', 'accordion' -%}
      {%- if product.description != blank or acc_blocks.size > 0 -%}
        <div class="wl-pd__accordion">
          {%- if product.description != blank -%}
            <details class="wl-pd__acc-item" open>
              <summary class="wl-pd__acc-header">
                <span class="wl-pd__acc-title">Product details</span>
                <span class="wl-pd__acc-caret" aria-hidden="true"></span>
              </summary>
              <div class="wl-pd__acc-body rte">{{ product.description }}</div>
            </details>
          {%- endif -%}
          {%- for block in acc_blocks -%}
            {%- if product.description != blank and block.settings.title == 'Product details' -%}
              {%- continue -%}
            {%- endif -%}
            <details class="wl-pd__acc-item" {{ block.shopify_attributes }}>
              <summary class="wl-pd__acc-header">
                <span class="wl-pd__acc-title">{{ block.settings.title }}</span>
                <span class="wl-pd__acc-caret" aria-hidden="true"></span>
              </summary>
              <div class="wl-pd__acc-body rte">{{ block.settings.content }}</div>
            </details>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<script>
var WlPd = (function () {
  var variants = {{ product.variants | json }};
  var moneyFormat = {{ shop.money_format | json }};

  function formatMoney(cents) {
    var value = (cents / 100).toFixed(2);
    return moneyFormat
      .replace(/\{\{\s*amount\s*\}\}/, value)
      .replace(/\{\{\s*amount_no_decimals\s*\}\}/, Math.round(cents / 100))
      .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, value.replace('.', ','))
      .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/, Math.round(cents / 100));
  }

  function getSelectedValues(sectionId) {
    var pills = document.querySelectorAll('#WlPdOptions-' + sectionId + ' .wl-pd__pill.is-active');
    var vals = [];
    pills.forEach(function (p) { vals[parseInt(p.dataset.optionIndex)] = p.dataset.value; });
    return vals;
  }

  function findVariant(vals) {
    return variants.find(function (v) {
      return vals.every(function (val, i) { return v['option' + (i + 1)] === val; });
    }) || null;
  }

  function applyVariant(variant, sectionId) {
    var priceEl   = document.getElementById('WlPdPrice-' + sectionId);
    var priceWas  = document.getElementById('WlPdPriceWas-' + sectionId);
    var variantId = document.getElementById('WlPdVariantId-' + sectionId);
    var btn       = document.getElementById('WlPdAddBtn-' + sectionId);
    var label     = document.getElementById('WlPdAddLabel-' + sectionId);

    if (!variant) return;

    if (priceEl) priceEl.textContent = formatMoney(variant.price);

    if (priceWas) {
      if (variant.compare_at_price > variant.price) {
        priceWas.textContent = formatMoney(variant.compare_at_price);
        priceWas.hidden = false;
      } else {
        priceWas.hidden = true;
      }
    }

    if (variantId) variantId.value = variant.id;

    if (btn && label) {
      label.textContent = variant.available
        ? (btn.dataset.addLabel || 'Add to cart')
        : (btn.dataset.soldOutLabel || 'Sold out');
      var persSetVariant = window['WlPersSetVariant_' + sectionId];
      if (persSetVariant) {
        persSetVariant(!!variant.available);
      } else {
        btn.disabled = !variant.available;
      }
    }
  }

  return {
    selectOption: function (btn, sectionId) {
      var idx = btn.dataset.optionIndex;
      btn.closest('.wl-pd__pills').querySelectorAll('.wl-pd__pill').forEach(function (p) {
        p.classList.remove('is-active');
        p.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-pressed', 'true');

      var valEl = document.getElementById('WlPdOptVal-' + sectionId + '-' + idx);
      if (valEl) valEl.textContent = btn.dataset.value;

      applyVariant(findVariant(getSelectedValues(sectionId)), sectionId);
    },
    setMedia: function (btn, sectionId) {
      var img = document.getElementById('WlPdImg-' + sectionId);
      if (img) { img.src = btn.dataset.src; img.alt = btn.dataset.alt; }
      btn.closest('.wl-pd__thumbs').querySelectorAll('.wl-pd__thumb').forEach(function (t) {
        t.classList.remove('is-active');
      });
      btn.classList.add('is-active');
    },
    adjustQty: function (delta, sectionId) {
      var input = document.getElementById('WlPdQty-' + sectionId);
      if (input) input.value = Math.max(1, (parseInt(input.value) || 1) + delta);
    },
  };
})();

document.addEventListener('DOMContentLoaded', function () {
  var addBtn = document.getElementById('WlPdAddBtn-{{ section.id }}');
  var textInput = document.getElementById('WlPersText-{{ section.id }}');
  var uploadInput = document.getElementById('WlPersUpload-{{ section.id }}');

  if (!textInput && !uploadInput) return;

  var ctaStack = addBtn && addBtn.closest('.wl-pd__cta-stack');
  var urlInput = document.getElementById('WlPersPhotoUrl-{{ section.id }}');
  var endpoint = uploadInput && uploadInput.dataset.endpoint;
  var hasText = false;
  var hasPhoto = false;
  var variantAvailable = {{ current_variant.available | json }};
  var textRequired = {{ section.settings.text_field_required | default: true | json }};

  function setCtaDisabled(disabled) {
    if (addBtn) addBtn.disabled = disabled;
    if (ctaStack) {
      ctaStack.querySelectorAll('.shopify-payment-button button').forEach(function (btn) {
        btn.disabled = disabled;
      });
    }
  }

  function updateCtaState() {
    var gated = textRequired ? !(hasText || hasPhoto) : false;
    setCtaDisabled(!variantAvailable || gated);
  }

  window['WlPersSetVariant_{{ section.id }}'] = function (available) {
    variantAvailable = available;
    updateCtaState();
  };

  setCtaDisabled(!variantAvailable || textRequired);

  if (textInput) {
    textInput.addEventListener('input', function () {
      hasText = textInput.value.trim().length > 0;
      updateCtaState();
    });
  }

  if (uploadInput) {
    FilePond.registerPlugin(
      FilePondPluginImagePreview,
      FilePondPluginFileValidateType,
      FilePondPluginFileValidateSize
    );

    FilePond.create(uploadInput, {
      credits: false,
      allowMultiple: false,
      maxFiles: 1,
      maxFileSize: '20MB',
      acceptedFileTypes: ['image/jpeg', 'image/png', 'image/heic', 'image/heif'],
      labelIdle: '<div class="wl-fp-idle"><svg class="wl-fp-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg><span class="wl-fp-text">Drag &amp; drop your photo here</span><span class="wl-fp-sub">JPG, PNG or HEIC &middot; max 20MB</span><span class="filepond--label-action">Browse files</span></div>',
      labelFileTypeNotAllowed: 'Please upload a PNG, JPG, or HEIC image',
      labelMaxFileSizeExceeded: 'File too large — max 20MB',
      fileValidateTypeDetectType: function (source, type) {
        return new Promise(function (resolve) {
          if (!type) {
            var ext = source.name.split('.').pop().toLowerCase();
            var map = { heic: 'image/heic', heif: 'image/heif', jpg: 'image/jpeg', jpeg: 'image/jpeg', png: 'image/png' };
            resolve(map[ext] || type);
          } else {
            resolve(type);
          }
        });
      },
      server: {
        process: function (fieldName, file, metadata, load, error, progress, abort) {
          if (!endpoint) { error('Upload not configured'); return; }
          var fileType = file.type || (/\.(heic|heif)$/i.test(file.name) ? 'image/heic' : 'image/jpeg');
          var xhr;

          fetch(endpoint + '/presign?fileType=' + encodeURIComponent(fileType))
            .then(function (r) { return r.json(); })
            .then(function (data) {
              xhr = new XMLHttpRequest();
              xhr.open('PUT', data.uploadUrl);
              xhr.setRequestHeader('Content-Type', fileType);
              xhr.upload.onprogress = function (e) { progress(e.lengthComputable, e.loaded, e.total); };
              xhr.onload = function () {
                if (xhr.status >= 200 && xhr.status < 300) {
                  if (urlInput) urlInput.value = data.viewUrl;
                  load(data.viewUrl);
                } else {
                  error('Upload failed');
                }
              };
              xhr.onerror = function () { error('Upload failed'); };
              xhr.send(file);
            })
            .catch(function () { error('Could not get upload URL'); });

          return { abort: function () { if (xhr) xhr.abort(); abort(); } };
        },
        revert: function (uniqueFileId, load) {
          if (urlInput) urlInput.value = '';
          load();
        }
      },
      onaddfilestart: function () {
        setCtaDisabled(true);
      },
      onprocessfile: function (error) {
        hasPhoto = !error;
        updateCtaState();
      },
      onprocessfileabort: function () {
        updateCtaState();
      },
      onremovefile: function () {
        hasPhoto = false;
        if (urlInput) urlInput.value = '';
        updateCtaState();
      }
    });
  }
});
</script>

{% schema %}
{
  "name": "WL Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "price_note",
      "label": "Price note",
      "placeholder": "e.g. per mug · free shipping over $50"
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "header",
      "content": "Personalization"
    },
    {
      "type": "checkbox",
      "id": "show_personalization",
      "label": "Show personalization panel",
      "default": false
    },
    {
      "type": "text",
      "id": "personalization_heading",
      "label": "Panel heading",
      "default": "Personalize your item"
    },
    {
      "type": "checkbox",
      "id": "show_text_field",
      "label": "Show custom text field",
      "default": true
    },
    {
      "type": "text",
      "id": "text_field_label",
      "label": "Text field label",
      "default": "Custom text (optional)"
    },
    {
      "type": "text",
      "id": "text_field_placeholder",
      "label": "Text field placeholder",
      "default": "e.g. Mom's Favorite, Best Dad…"
    },
    {
      "type": "text",
      "id": "text_field_property",
      "label": "Line item property name",
      "default": "Custom text",
      "info": "This label appears on the order and packing slip"
    },
    {
      "type": "checkbox",
      "id": "text_field_required",
      "label": "Require text before adding to cart",
      "default": true
    },
    {
      "type": "range",
      "id": "text_field_max_length",
      "label": "Max characters",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "checkbox",
      "id": "show_upload_field",
      "label": "Show photo upload field",
      "default": true
    },
    {
      "type": "text",
      "id": "upload_field_label",
      "label": "Upload field label",
      "default": "Upload your photo"
    },
    {
      "type": "text",
      "id": "upload_endpoint",
      "label": "Upload endpoint URL",
      "info": "API Gateway base URL — no trailing slash (e.g. https://xxx.execute-api.us-east-1.amazonaws.com)"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "badge",
      "name": "Feature badge",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "In-house printed"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary (blue)" },
            { "value": "secondary", "label": "Secondary (gray)" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "trust_item",
      "name": "Trust item",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
