{{ 'wl-tokens.css' | asset_url | stylesheet_tag }}
{{ 'wl-buttons.css' | asset_url | stylesheet_tag }}
{{ 'wl-section-header.css' | asset_url | stylesheet_tag }}
{{ 'wl-product-card.css' | asset_url | stylesheet_tag }}
{{ 'wl-product-recs.css' | asset_url | stylesheet_tag }}

<div
  class="wl-recs"
  id="WlRecs-{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-section-id="{{ section.id }}"
>
  {%- if recommendations.performed? and recommendations.products_count > 0 -%}
    <div class="page-width">
      {%- render 'wl-section-header',
        title: section.settings.heading
      -%}
      <div class="wl-recs__grid">
        {%- for rec in recommendations.products limit: section.settings.products_to_show -%}
          <div class="wl-pc">
            <a class="wl-pc__img-wrap" href="{{ rec.url }}">
              <div class="wl-pc__img">
                {%- if rec.featured_image -%}
                  <img
                    src="{{ rec.featured_image | image_url: width: 400 }}"
                    alt="{{ rec.featured_image.alt | default: rec.title | escape }}"
                    width="400"
                    height="400"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="wl-pc__img-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--wl-gray-300)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>
            </a>
            <div class="wl-pc__body">
              <p class="wl-pc__name"><a href="{{ rec.url }}">{{ rec.title }}</a></p>
              {%- if rec.description != blank -%}
                <p class="wl-pc__desc">{{ rec.description | strip_html | truncate: 75 }}</p>
              {%- endif -%}
              <div class="wl-pc__foot">
                <div class="wl-pc__price">
                  {%- if rec.compare_at_price > rec.price -%}
                    <s class="wl-pc__price-was">{{ rec.compare_at_price | money }}</s>
                  {%- endif -%}
                  {{ rec.price | money }}
                </div>
                <a href="{{ rec.url }}" class="wl-btn wl-btn--sm wl-btn--secondary">View</a>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var el = document.getElementById('WlRecs-{{ section.id }}');
  if (!el) return;
  fetch(
    '/recommendations/products?section_id=' + el.dataset.sectionId +
    '&product_id=' + el.dataset.productId +
    '&limit={{ section.settings.products_to_show }}'
  )
    .then(function (r) { return r.text(); })
    .then(function (html) {
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var inner = doc.getElementById('WlRecs-' + el.dataset.sectionId);
      if (inner) el.innerHTML = inner.innerHTML;
    });
})();
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You might also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
