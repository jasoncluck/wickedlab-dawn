{{ 'wl-tokens.css' | asset_url | stylesheet_tag }}
{{ 'wl-buttons.css' | asset_url | stylesheet_tag }}
{{ 'wl-section-header.css' | asset_url | stylesheet_tag }}
{{ 'wl-featured-products.css' | asset_url | stylesheet_tag }}

<div class="wl-feat-section">
  <div class="page-width">

    {%- render 'wl-section-header',
      eyebrow: section.settings.eyebrow,
      title: section.settings.title,
      all_link_label: section.settings.all_link_label,
      all_link_url: section.settings.all_link_url
    -%}

    <div class="wl-feat__grid">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div class="wl-prod-card{% if block.settings.featured %} wl-prod-card--featured{% endif %}"
             {{ block.shopify_attributes }}>

          {%- comment -%} ── Image area ── {%- endcomment -%}
          <a href="{{ product.url }}" class="wl-prod-card__image-link">
            <div class="wl-prod-card__image-wrap"
                 style="background-color: {{ block.settings.bg_color }};">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 600 | image_tag:
                   loading: 'lazy',
                   class: 'wl-prod-card__img',
                   alt: product.featured_image.alt | escape }}
              {%- else -%}
                <span class="wl-prod-card__placeholder">Product image</span>
              {%- endif -%}

              {%- if block.settings.badge != blank -%}
                <span class="wl-badge wl-badge--{{ block.settings.badge_style }}">
                  {{ block.settings.badge }}
                </span>
              {%- endif -%}
            </div>
          </a>

          {%- comment -%} ── Card body ── {%- endcomment -%}
          <div class="wl-prod-card__body">
            {%- if product.type != blank -%}
              <p class="wl-prod-card__cat">{{ product.type }}</p>
            {%- endif -%}
            <a href="{{ product.url }}" class="wl-prod-card__name-link">
              <p class="wl-prod-card__name">{{ product.title }}</p>
            </a>
            {%- if block.settings.description != blank -%}
              <p class="wl-prod-card__desc">{{ block.settings.description }}</p>
            {%- elsif product.description != blank -%}
              <p class="wl-prod-card__desc">{{ product.description | strip_html | truncate: 80 }}</p>
            {%- endif -%}

            <div class="wl-prod-card__footer">
              <span class="wl-prod-card__price">
                {{ product.price | money }}
              </span>

              {%- if product.variants.size == 1 and product.available and product.template_suffix != 'personalizable' and product.template_suffix != 'text-only' -%}
                <form action="/cart/add" method="post">
                  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="wl-btn-add">Add to cart</button>
                </form>
              {%- else -%}
                <a href="{{ product.url }}" class="wl-btn-options">
                  {%- if product.available -%}Choose options{%- else -%}Sold out{%- endif -%}
                </a>
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "WL - Featured Products",
  "tag": "section",
  "class": "wl-feat-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow line",
      "default": "Hand-picked for you"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "text",
      "id": "all_link_label",
      "label": "\"See all\" link text",
      "default": "See all products →"
    },
    {
      "type": "url",
      "id": "all_link_url",
      "label": "\"See all\" link URL"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Card description",
          "info": "Overrides the product description. Keep to ~80 characters."
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Image background colour",
          "default": "#F0F2F5"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured card (blue border glow)",
          "default": false
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "info": "e.g. Best seller, New, Popular — leave blank for none"
        },
        {
          "type": "select",
          "id": "badge_style",
          "label": "Badge style",
          "options": [
            { "value": "hot",  "label": "Bold (Best seller)" },
            { "value": "soft", "label": "Soft (New / Popular)" }
          ],
          "default": "hot"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WL Featured Products",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "bg_color": "#E8EDF2",
            "featured": true,
            "badge": "Best seller",
            "badge_style": "hot",
            "description": "Printed in-house on quality ceramic. Your photo, your message."
          }
        },
        {
          "type": "product",
          "settings": {
            "bg_color": "#EDE8F2",
            "featured": false,
            "badge": "Popular",
            "badge_style": "soft",
            "description": "300 or 500 pieces. Perfect birthday or anniversary gift."
          }
        },
        {
          "type": "product",
          "settings": {
            "bg_color": "#E8F2ED",
            "featured": false,
            "description": "Custom photo. Great for parties & weddings."
          }
        },
        {
          "type": "product",
          "settings": {
            "bg_color": "#F2EEE8",
            "featured": false,
            "description": "Laser engraved natural slate. A timeless keepsake."
          }
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
