{{ 'wl-hero.css' | asset_url | stylesheet_tag }}

<div class="wl-hero-section">
  <div class="wl-hero page-width">

    {%- comment -%} ── LEFT: text column ── {%- endcomment -%}
    <div class="wl-hero__text">

      <p class="wl-hero__eyebrow">{{ section.settings.eyebrow }}</p>

      <h1 class="wl-hero__h1">
        <span class="wl-hero__h1-line1">{{ section.settings.heading_line1 }}</span>
        <span class="wl-hero__h1-line2">{{ section.settings.heading_line2 }}</span>
      </h1>

      <p class="wl-hero__body">{{ section.settings.body }}</p>

      <div class="wl-hero__btns">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_url }}" class="wl-btn-primary">
            {{ section.settings.btn_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_url }}" class="wl-btn-secondary">
            {{ section.settings.btn_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="wl-hero__trust">
        {%- for i in (1..4) -%}
          {%- assign key = 'trust_' | append: i -%}
          {%- if section.settings[key] != blank -%}
            <div class="wl-trust-item">
              <span class="wl-trust-dot"></span>
              {{ section.settings[key] }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} ── RIGHT: product panel ── {%- endcomment -%}
    <div class="wl-hero__panel">

      <p class="wl-panel__label">{{ section.settings.panel_label }}</p>

      {%- for block in section.blocks -%}
        {%- if block.type == 'product_row' -%}
          <div class="wl-panel__row" {{ block.shopify_attributes }}>
            <div>
              <div class="wl-panel__tag">{{ block.settings.tag }}</div>
              <div class="wl-panel__name">{{ block.settings.name }}</div>
            </div>
            <div class="wl-panel__price">{{ block.settings.price }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "WL - Hero",
  "tag": "section",
  "class": "wl-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow line",
      "default": "York, PA · In-house printing since 2015"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — line 1",
      "default": "Every gift,"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — line 2 (bold)",
      "default": "made just for you"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "No set-up fee. No minimum order. Custom-printed in-house — mugs, apparel, puzzles, laser engraving, and more. Ships in 5–7 business days."
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Label",
      "default": "Shop all gifts"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Label",
      "default": "Get a promo quote"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Badge 1",
      "default": "No set-up fee"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Badge 2",
      "default": "No minimum order"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Badge 3",
      "default": "Ships in 5–7 days"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Badge 4",
      "default": "In-house printed"
    },
    {
      "type": "header",
      "content": "Product panel"
    },
    {
      "type": "text",
      "id": "panel_label",
      "label": "Panel heading",
      "default": "Top products this week"
    }
  ],
  "blocks": [
    {
      "type": "product_row",
      "name": "Product row",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (e.g. Best seller, New)",
          "default": "Best seller"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Product name",
          "default": "Custom Photo Mug"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$15.00"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WL Hero",
      "blocks": [
        {
          "type": "product_row",
          "settings": {
            "tag": "Best seller",
            "name": "Custom Photo Mug",
            "price": "$15.00"
          }
        },
        {
          "type": "product_row",
          "settings": {
            "tag": "New",
            "name": "Laser Engraved Gift",
            "price": "From $15.00"
          }
        },
        {
          "type": "product_row",
          "settings": {
            "tag": "Popular",
            "name": "Custom Photo Puzzle",
            "price": "$21.50"
          }
        },
        {
          "type": "product_row",
          "settings": {
            "tag": "Limited",
            "name": "3D Printed Keepsake",
            "price": "From $19.50"
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
