{{ 'wl-tokens.css' | asset_url | stylesheet_tag }}
{{ 'wl-buttons.css' | asset_url | stylesheet_tag }}
{{ 'wl-hero.css' | asset_url | stylesheet_tag }}

<div class="wl-hero-section">
  <div class="wl-hero page-width">

    {%- comment -%} ── LEFT: logo + heading ── {%- endcomment -%}
    <div class="wl-hero__left">

      {%- if section.settings.hero_logo != blank -%}
        <div class="wl-hero__logo">
          <img
            src="{{ section.settings.hero_logo | asset_url }}"
            alt="{{ shop.name | escape }}"
            height="{{ section.settings.hero_logo_height }}"
            style="height: {{ section.settings.hero_logo_height }}px; width: auto;"
            loading="eager"
          >
        </div>
      {%- endif -%}

      <p class="wl-hero__eyebrow">{{ section.settings.eyebrow }}</p>

    </div>

    {%- comment -%} ── RIGHT: heading + body + actions ── {%- endcomment -%}
    <div class="wl-hero__right">

      <h1 class="wl-hero__h1">
        <span class="wl-hero__h1-line1">{{ section.settings.heading_line1 }}</span>
        <span class="wl-hero__h1-line2">{{ section.settings.heading_line2 }}</span>
      </h1>

      <p class="wl-hero__body">{{ section.settings.body }}</p>

      <div class="wl-hero__btns">
        {%- if section.settings.btn_primary_label != blank -%}
          <a href="{{ section.settings.btn_primary_url }}" class="wl-btn-primary">
            {{ section.settings.btn_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn_secondary_label != blank -%}
          <a href="{{ section.settings.btn_secondary_url }}" class="wl-btn-secondary">
            {{ section.settings.btn_secondary_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="wl-hero__trust">
        {%- for i in (1..4) -%}
          {%- assign key = 'trust_' | append: i -%}
          {%- if section.settings[key] != blank -%}
            <div class="wl-trust-item">
              <span class="wl-trust-dot"></span>
              {{ section.settings[key] }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "WL - Hero",
  "tag": "section",
  "class": "wl-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand logo"
    },
    {
      "type": "text",
      "id": "hero_logo",
      "label": "Logo asset filename",
      "info": "Filename of an SVG or PNG in the theme assets folder (e.g. TWL_shopify_logo.svg). Leave blank to hide.",
      "default": "TWL_shopify_logo.svg"
    },
    {
      "type": "range",
      "id": "hero_logo_height",
      "label": "Logo height (px)",
      "min": 30,
      "max": 200,
      "step": 5,
      "default": 120
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow line",
      "default": "York, PA · In-house printing since 2015"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — line 1",
      "default": "Every gift,"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — line 2 (bold)",
      "default": "made just for you"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "No set-up fee. No minimum order. Custom-printed in-house — mugs, apparel, puzzles, laser engraving, and more. Ships in 5–7 business days."
    },
    {
      "type": "header",
      "content": "Primary button"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Label",
      "default": "Shop all gifts"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Secondary button"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Label",
      "default": "Get a promo quote"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Trust badges"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Badge 1",
      "default": "No set-up fee"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Badge 2",
      "default": "No minimum order"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Badge 3",
      "default": "Ships in 5–7 days"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Badge 4",
      "default": "In-house printed"
    }
  ],
  "presets": [
    {
      "name": "WL Hero"
    }
  ]
}
{% endschema %}
